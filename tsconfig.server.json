{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "outDir": "dist/server",
    "rootDir": "src",
    "types": ["node"],
    "noEmit": false
  },
  "include": [
    "src/server/**/*.ts",
    "src/import/**/*.ts",
    "src/counting/**/*.ts",
    "src/operational/**/*.ts",
    "src/system/**/*.ts",
    "src/db/**/*.ts",
    "src/domain/**/*.ts",
    "src/shared/**/*.ts",
    "src/match/**/*.ts",
    "src/separation/**/*.ts",
    "src/auth/**/*.ts",
    "src/audit/**/*.ts",
    "src/staff/**/*.ts",
    "src/repair/**/*.ts",
    "src/datasys/**/*.ts",
    "src/import-central/**/*.ts",
    "src/analise/**/*.ts",
    "src/dashboard/**/*.ts",
    "src/issue/**/*.ts"
  ]
}
