# Porta do backend Express (API)
SERVER_PORT=3001

# Host em que o backend escuta. Padrão 127.0.0.1 (somente local) — enquanto
# não houver autenticação e a leitura de Excel (lib xlsx) continuar processando
# uploads de terceiros, NÃO exponha em 0.0.0.0 sem outra camada de proteção.
# Beta local, somente arquivos confiáveis.
SERVER_HOST=127.0.0.1

# Porta do servidor de desenvolvimento do Vite (frontend)
CLIENT_PORT=5173

# Caminho do banco SQLite operacional (relativo à raiz do projeto)
DATABASE_PATH=data/app.sqlite

# Diretório para uploads temporários durante a importação.
# Os arquivos enviados são gravados aqui e apagados após a importação.
UPLOAD_TMP_DIR=data/tmp

# Tamanho máximo aceito por arquivo no upload (em MB)
MAX_UPLOAD_MB=200

# Percentual mínimo (0 a 1) do total bipado em relação ao estoque legado do
# lote vinculado à sessão. Abaixo disso, a finalização normal é bloqueada
# (warning COUNT_BELOW_BASELINE_THRESHOLD); só permite finalização forçada
# com responsável + justificativa de pelo menos 10 caracteres.
COUNT_MIN_COMPLETENESS_RATIO=0.80

# A importação Excel só é usada para INICIALIZAR o sistema. Depois da primeira
# importação confirmada, novas importações são bloqueadas (HTTP 409). Deixe em
# false no beta normal; só use true em dev/teste para reabrir a importação.
ALLOW_LEGACY_REIMPORT=false
