{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "scripts/**/*.ts",
    "src/server/**/*.ts",
    "src/import/**/*.ts",
    "src/counting/**/*.ts",
    "src/db/**/*.ts",
    "src/domain/**/*.ts",
    "src/shared/**/*.ts",
    "src/auth/**/*.ts",
    "src/audit/**/*.ts",
    "src/staff/**/*.ts",
    "src/repair/**/*.ts",
    "src/datasys/**/*.ts",
    "src/operational/**/*.ts",
    "src/system/**/*.ts",
    "src/match/**/*.ts",
    "src/separation/**/*.ts"
  ]
}
