{
  "name": "sistema-pecas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node dist/server/server/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "audit:real": "tsx scripts/audit-real.ts",
    "initialize:existing": "tsx scripts/initialize-existing.ts",
    "migrate:repair-domain": "tsx scripts/migrate-repair-domain.ts",
    "user:ensure-admin": "tsx scripts/ensure-admin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "cleanup:invalid-reservations": "tsx scripts/cleanup-invalid-reservations.ts",
    "beta:init": "tsx scripts/beta-init.ts",
    "beta:start": "tsx scripts/beta-start.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.scripts.json --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "lucide-react": "^1.23.0",
    "multer": "^2.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
